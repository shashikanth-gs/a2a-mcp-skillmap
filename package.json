{
  "name": "a2a-mcp-skillmap",
  "version": "0.1.0",
  "description": "Turn any A2A agent into an MCP tool server. Dynamic skill discovery, multimodal output, stdio + HTTP transports. Zero glue code.",
  "type": "module",
  "bin": {
    "a2a-mcp-skillmap": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.map",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shashikanth-gs/a2a-mcp-skillmap.git"
  },
  "bugs": {
    "url": "https://github.com/shashikanth-gs/a2a-mcp-skillmap/issues"
  },
  "homepage": "https://github.com/shashikanth-gs/a2a-mcp-skillmap#readme",
  "author": "Shashikanth <shashikanth-gs@users.noreply.github.com>",
  "scripts": {
    "build": "tsc",
    "build:publish": "tsc -p tsconfig.publish.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build:publish"
  },
  "keywords": [
    "a2a",
    "mcp",
    "agent",
    "bridge",
    "model-context-protocol",
    "agent-to-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@a2a-js/sdk": "0.3.13",
    "@modelcontextprotocol/sdk": "1.29.0",
    "commander": "14.0.3",
    "express": "5.2.1",
    "pino": "10.3.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "22.15.29",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "9.28.0",
    "fast-check": "4.7.0",
    "prettier": "3.8.3",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  }
}
